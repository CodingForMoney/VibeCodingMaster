{
  "name": "vibe-coding-master",
  "version": "0.0.2",
  "description": "Local GUI session cockpit for Claude Code role sessions.",
  "type": "module",
  "files": [
    "dist",
    "dist-frontend",
    "docs",
    "scripts",
    "README.md"
  ],
  "bin": {
    "vcm": "dist/main.js",
    "vcmctl": "dist/cli/vcmctl.js"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node scripts/clean-build.mjs",
    "fix:node-pty": "node scripts/fix-node-pty-spawn-helper.mjs",
    "postinstall": "node scripts/fix-node-pty-spawn-helper.mjs",
    "dev": "tsx src/main.ts --dev",
    "build": "npm run clean && tsc -p tsconfig.node.json && vite build",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "execa": "^9.6.0",
    "fastify": "^5.3.3",
    "node-pty": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.18.2",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.24",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
