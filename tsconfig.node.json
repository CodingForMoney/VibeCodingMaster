{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/main.ts", "src/backend/**/*.ts", "src/cli/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["dist", "dist-frontend", "node_modules", "tests"]
}
